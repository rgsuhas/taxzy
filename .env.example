# ── Docker Compose ────────────────────────────────────────────────────────────
# Postgres credentials (used by docker-compose.yml)
POSTGRES_DB=taxzy
POSTGRES_USER=taxzy_user
POSTGRES_PASSWORD=changeme_in_production

# Frontend API URL when running via Docker
# For local docker-compose, keep as localhost:8000
# For Fly.io + Vercel, set to your Fly app URL e.g. https://taxzy-backend.fly.dev
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Backend (copy these to backend/.env) ──────────────────────────────────────
DATABASE_URL=postgresql://taxzy_user:changeme_in_production@localhost:5432/taxzy
GEMINI_API_KEY=your_gemini_api_key_here
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24
SETU_API_KEY=your_setu_api_key_here
SETU_API_URL=https://dg-sandbox.setu.co
# Comma-separated allowed CORS origins (defaults to localhost:3000)
CORS_ORIGINS=http://localhost:3000
